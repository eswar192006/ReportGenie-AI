# Environment variables for production deployment

# Backend API URL (set this in Vercel for frontend to communicate with deployed backend)
# Example: https://reportgenie-backend.railway.app
# VITE_API_URL=

# Backend environment variables (if using Ollama for AI features)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=mistral:latest
# OLLAMA_TIMEOUT_SECONDS=20
# SCHEMA_LLM_ASSIST=1
# SCHEMA_LLM_CONFIDENCE_THRESHOLD=1.35

# CORS configuration (comma-separated list of allowed origins)
# CORS_ALLOW_ORIGINS=https://your-domain.vercel.app,https://custom-domain.com

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Port configuration for backend (usually set by hosting platform)
# PORT=8000
