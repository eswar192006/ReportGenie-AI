{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL (e.g., https://reportgenie-backend.herokuapp.com or your deployed API endpoint)",
      "required": false
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "${VITE_API_URL}/api/:path*"
    },
    {
      "source": "/outputs/:path*",
      "destination": "${VITE_API_URL}/outputs/:path*"
    },
    {
      "source": "/sample_data/:path*",
      "destination": "${VITE_API_URL}/sample_data/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
